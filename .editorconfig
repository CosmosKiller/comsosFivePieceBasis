# Cosmos Matter monorepo — see docs/CODE_STYLE.md
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,cpp,h,hpp}]
indent_style = space
indent_size = 4

[CMakeLists.txt]
indent_style = space
indent_size = 4

[*.{md,MD}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
